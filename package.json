{
    "name": "ioserver-oidc",
    "version": "0.1.1",
    "description": "IOServer middleware set for OIDC/OAuth2 JWT authentication via JWKS (auth-service compatible)",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "version:minor": "pnpm version minor --no-git-tag-version",
        "version:major": "pnpm version major --no-git-tag-version",
        "gpr-setup": "node scripts/gpr.js",
        "gpr-restore": "node scripts/gpr-restore.js",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "ioserver",
        "oidc",
        "oauth2",
        "jwt",
        "middleware",
        "fastify",
        "socket.io",
        "auth-service"
    ],
    "author": "x42en <https://github.com/x42en>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/x42en/ioserver-oidc.git"
    },
    "homepage": "https://github.com/x42en/ioserver-oidc#readme",
    "bugs": {
        "url": "https://github.com/x42en/ioserver-oidc/issues"
    },
    "peerDependencies": {
        "ioserver": ">=2.0.0"
    },
    "dependencies": {
        "jose": "^6.1.3"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "ioserver": "^2.1.1",
        "typescript": "^5.9.3"
    }
}
