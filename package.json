{
    "name": "ioserver-oidc",
    "version": "0.1.4",
    "description": "IOServer middleware set for OIDC/OAuth2 JWT authentication via JWKS (auth-service compatible)",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit",
        "test:integration": "vitest run tests/integration",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "lint": "eslint src tests",
        "lint:fix": "eslint src tests --fix",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "version:minor": "pnpm version minor --no-git-tag-version",
        "version:major": "pnpm version major --no-git-tag-version",
        "gpr-setup": "node scripts/gpr.cjs",
        "gpr-restore": "node scripts/gpr-restore.cjs",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "ioserver",
        "oidc",
        "oauth2",
        "jwt",
        "middleware",
        "fastify",
        "socket.io",
        "auth-service"
    ],
    "author": "x42en <https://github.com/x42en>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/x42en/ioserver-oidc.git"
    },
    "homepage": "https://github.com/x42en/ioserver-oidc#readme",
    "bugs": {
        "url": "https://github.com/x42en/ioserver-oidc/issues"
    },
    "peerDependencies": {
        "ioserver": ">=2.0.0"
    },
    "dependencies": {
        "jose": "^6.1.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.0",
        "ioserver": "^2.1.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.4"
    }
}
