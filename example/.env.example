# ── Réseau ────────────────────────────────────────────────────────────────────
# IP LAN de la machine hôte (celle qui exécute Docker).
# Linux :  ip route get 1.1.1.1 | awk '{print $7}' | head -1
# macOS :  ipconfig getifaddr en0
HOST_IP=192.168.1.100

# TLD local — évitez .local (réservé mDNS/Zeroconf).
# Les services seront exposés sous auth.<DOMAIN> et app.<DOMAIN>.
DOMAIN=demo.test

# ── Auth-service bootstrap ────────────────────────────────────────────────────
# Compte superadmin créé automatiquement au premier démarrage.
ADMIN_EMAIL=admin@demo.test
ADMIN_PASSWORD=Admin1234!

# Clé secrète BetterAuth (32 octets min) — générer : openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-please-generate-a-real-secret

# ── Base de données ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=pgpassword

# ── Application OAuth demo ────────────────────────────────────────────────────
# Slug = client_id OAuth. Doit être unique dans auth-service.
APP_SLUG=oidc-demo

# ── PKI interne (upki-ca + upki-ra) ──────────────────────────────────────────
# Seed partagé entre le CA et la RA pour l'enrôlement initial.
# Générer : openssl rand -base64 32
# Après le premier démarrage, ce secret n'est plus utilisé (la RA stocke ses
# certificats dans son volume persistant).
PKI_SEED=changeme-generate-with-openssl-rand-base64-32
